{
  "name": "tower-deploy-action",
  "main": "index.js",
  "scripts": {
    "lint": "eslint",
    "build": "tsc",
    "prepare": "npm run build && ncc build build/index.js -o dist --source-map --license licenses.txt",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "all": "npm run lint && npm run prepare && npm run test"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.0.2",
    "jest": "^30.3.0",
    "nock": "^14.0.11",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  }
}
